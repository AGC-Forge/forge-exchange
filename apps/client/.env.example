APP_NAME="Smart Boost Labs"
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_HOST=localhost
NUXT_PUBLIC_SITE_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:@localhost:5432/forge_exchangee"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="your-cloudinary-upload-preset"

REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

RESEND_API_KEY=""

NUXT_NODEMAILER_AUTH_USER="your-smtp-user@example.com"
NUXT_NODEMAILER_AUTH_PASS="your-smtp-password@example.com"
NUXT_NODEMAILER_FROM="Agc Forge <your-smtp-user@example.com>"

ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="your-admin-password"
ADMIN_NAME="your-admin-name"

NUXT_SESSION_PASSWORD=your-nuxt-session-password
APP_CLIENT_SECRET=your-app-client-secret

SANITY_PROJECT_ID="your-sanity-project-id"
SANITY_DATASET="your-sanity-dataset"
NUXT_SANITY_TOKEN=your-nuxt-sanity-token

JWT_ACCESS_SECRET=your-jwt-access-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

NUXT_OG_IMAGE_SECRET=your-nuxt-og-image-secret

MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_IS_PRODUCTION=true
XENDIT_SECRET_KEY="your-xendit-secret-key"
XENDIT_WEBHOOK_TOKEN="your-xendit-webhook-token"

# PayPal Payment Gateway
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"
PAYPAL_MODE="sandbox"

# Exchange Rate API (for IDR → USD conversion for PayPal)
EXCHANGE_RATE_API_KEY="your-exchange-rate-api-key"
