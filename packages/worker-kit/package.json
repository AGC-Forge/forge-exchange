{
  "name": "@forge-exchange/worker-kit",
  "version": "0.1.0",
  "description": "Shared worker runtime utilities (server-only)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "rimraf": "^6.1.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.0.9"
}
