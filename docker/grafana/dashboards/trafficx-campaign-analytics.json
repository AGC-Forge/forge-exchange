{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "description": "TrafficX — Campaign & Traffic Analytics",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Campaign Stats",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Running Campaigns",
      "type": "stat",
      "targets": [
        { "expr": "trafficx_active_campaigns or vector(0)", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Sessions Today",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(trafficx_sessions_total[24h])) or vector(0)",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Success Rate (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(trafficx_sessions_total{status='completed'}[1h])) / sum(rate(trafficx_sessions_total[1h])) or vector(1)",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Avg Session Duration",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(trafficx_session_duration_seconds) or vector(0)",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Credits Used (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(trafficx_credits_used_total[24h])) or vector(0)",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Failed Sessions (1h)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(trafficx_sessions_total{status='failed'}[1h])) or vector(0)",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic Trends",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Session Rate (success vs failed)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(trafficx_sessions_total{status='completed'}[5m]))",
          "legendFormat": "Completed",
          "refId": "A"
        },
        {
          "expr": "sum(rate(trafficx_sessions_total{status='failed'}[5m]))",
          "legendFormat": "Failed",
          "refId": "B"
        },
        {
          "expr": "sum(rate(trafficx_sessions_total{status='timeout'}[5m]))",
          "legendFormat": "Timeout",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "title": "Traffic by OS",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum(trafficx_sessions_total{os='windows'}) or vector(0)",
          "legendFormat": "Windows",
          "refId": "A"
        },
        {
          "expr": "sum(trafficx_sessions_total{os='macos'}) or vector(0)",
          "legendFormat": "macOS",
          "refId": "B"
        },
        {
          "expr": "sum(trafficx_sessions_total{os='linux'}) or vector(0)",
          "legendFormat": "Linux",
          "refId": "C"
        },
        {
          "expr": "sum(trafficx_sessions_total{os='android'}) or vector(0)",
          "legendFormat": "Android",
          "refId": "D"
        },
        {
          "expr": "sum(trafficx_sessions_total{os='ios'}) or vector(0)",
          "legendFormat": "iOS",
          "refId": "E"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "GEO Distribution",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Sessions by Country (Top 10)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "topk(10, sum by (country) (rate(trafficx_sessions_total[5m])))",
          "legendFormat": "{{ country }}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Failure Analysis",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "title": "Failure Reason Breakdown",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (error_type) (increase(trafficx_session_errors_total[1h]))",
          "legendFormat": "{{ error_type }}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Error Rate by Type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (error_type) (rate(trafficx_session_errors_total[5m]))",
          "legendFormat": "{{ error_type }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["trafficx", "campaigns", "analytics"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "TrafficX — Campaign Analytics",
  "uid": "trafficx-campaigns",
  "version": 1
}
