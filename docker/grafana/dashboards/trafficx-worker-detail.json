{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "description": "TrafficX — Worker Detail Dashboard",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Worker Summary",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "Workers Online",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(trafficx_worker_status{status='online'}) or vector(0)",
          "legendFormat": "Online",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Total Active Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(trafficx_worker_active_sessions) or vector(0)",
          "legendFormat": "Sessions",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Avg CPU Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(trafficx_worker_cpu_usage) or vector(0)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "title": "Avg RAM Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(trafficx_worker_ram_usage) or vector(0)",
          "legendFormat": "RAM",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Per-Worker Resources",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "CPU per Worker",
      "type": "timeseries",
      "targets": [
        {
          "expr": "trafficx_worker_cpu_usage",
          "legendFormat": "{{ worker_id }}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "RAM per Worker",
      "type": "timeseries",
      "targets": [
        {
          "expr": "trafficx_worker_ram_usage",
          "legendFormat": "{{ worker_id }}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Active Sessions per Worker",
      "type": "timeseries",
      "targets": [
        {
          "expr": "trafficx_worker_active_sessions",
          "legendFormat": "{{ worker_id }}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Active Browsers per Worker",
      "type": "timeseries",
      "targets": [
        {
          "expr": "trafficx_worker_active_browsers",
          "legendFormat": "{{ worker_id }}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Worker Table (Current State)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "trafficx-prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM %" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 20,
      "options": { "showHeader": true, "footer": { "show": false } },
      "title": "Worker Status Table",
      "type": "table",
      "targets": [
        {
          "expr": "trafficx_worker_cpu_usage",
          "legendFormat": "{{ worker_id }}",
          "instant": true,
          "refId": "A",
          "format": "table"
        },
        {
          "expr": "trafficx_worker_ram_usage",
          "legendFormat": "{{ worker_id }}",
          "instant": true,
          "refId": "B",
          "format": "table"
        },
        {
          "expr": "trafficx_worker_active_sessions",
          "legendFormat": "{{ worker_id }}",
          "instant": true,
          "refId": "C",
          "format": "table"
        },
        {
          "expr": "trafficx_worker_active_browsers",
          "legendFormat": "{{ worker_id }}",
          "instant": true,
          "refId": "D",
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "CPU %",
              "Value #B": "RAM %",
              "Value #C": "Sessions",
              "Value #D": "Browsers",
              "worker_id": "Worker ID"
            }
          }
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["trafficx", "worker"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "TrafficX — Worker Detail",
  "uid": "trafficx-workers",
  "version": 1
}
