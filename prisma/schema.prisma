generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "rhel-openssl-1.0.x", "debian-openssl-3.0.x", "darwin-arm64", "windows", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
}

enum GenJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Role {
  id         String   @id @default(cuid())
  name       String   @db.Text
  level      Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz
  users      User[]

  @@unique([name, level], name: "role_name_level_unique")
  @@index([name], name: "role_name_idx")
  @@index([level], name: "role_level_idx")
  @@map("roles")
}

model Account {
  id                  String  @id @default(cuid())
  user                User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id             String
  type                String
  provider            String
  provider_account_id String
  refresh_token       String? @db.Text
  access_token        String? @db.Text
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String? @db.Text
  session_state       String?

  @@unique([provider, provider_account_id], name: "account_provider_provider_account_id_unique")
  @@index([user_id], name: "account_user_id_idx")
  @@index([provider], name: "account_provider_idx")
  @@map("accounts")
}

model Session {
  id            String   @id @default(cuid())
  session_token String   @unique
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       String
  expires       DateTime

  @@index([user_id], name: "session_user_id_idx")
  @@map("sessions")
}

model User {
  id                String    @id @default(cuid())
  name              String    @db.Text
  email             String    @unique @db.Text
  phone             String?   @unique @db.Text
  password_hash     String?   @db.Text
  avatar            String?   @db.Text
  role              Role      @relation(fields: [role_id], references: [id], onDelete: Cascade)
  role_id           String
  email_verified_at DateTime?
  last_login_at     DateTime?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  accounts        Account[]
  sessions        Session[]
  password_resets PasswordResetToken[]

  @@unique([email, role_id], name: "user_email_role_id_unique")
  @@index([email], name: "user_email_idx")
  @@index([is_active], name: "user_is_active_idx")
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token], name: "verification_token_identifier_token_unique")
  @@index([token], name: "verification_token_token_idx")
  @@map("verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  token      String   @unique @db.Text
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires    DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([token], name: "password_reset_token_idx")
  @@index([user_id], name: "password_reset_user_id_idx")
  @@map("password_reset_tokens")
}

model Setting {
  id         String   @id @default(cuid())
  key        String   @db.Text
  value      String   @db.Text
  group_name String   @db.Text
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@unique([key, group_name], name: "setting_key_group_name_unique")
  @@index([key], name: "setting_key_idx")
  @@index([group_name], name: "setting_group_name_idx")
  @@map("settings")
}
