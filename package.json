{
  "name": "forge-exchange",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev:client": "pnpm --filter @forge-exchange/client dev",
    "dev:worker": "pnpm --filter @forge-exchange/worker dev",
    "build": "pnpm --filter @forge-exchange/client build",
    "build:worker": "pnpm --filter @forge-exchange/worker build",
    "build:all": "pnpm --filter @forge-exchange/client build && pnpm --filter @forge-exchange/worker build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @forge-exchange/client typecheck",
    "db:generate": "pnpm --filter @forge-exchange/db generate",
    "db:push": "pnpm --filter @forge-exchange/db push",
    "db:migrate": "pnpm --filter @forge-exchange/db migrate",
    "db:migrate:prod": "pnpm --filter @forge-exchange/db migrate:prod",
    "db:seed": "pnpm --filter @forge-exchange/db seed",
    "db:studio": "pnpm --filter @forge-exchange/db studio",
    "db:validate": "pnpm --filter @forge-exchange/db validate",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
