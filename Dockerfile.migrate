FROM node:20-alpine

WORKDIR /repo

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/db/package.json packages/db/package.json

RUN pnpm --filter @forge-exchange/db... install --frozen-lockfile

COPY packages/db packages/db

RUN pnpm --filter @forge-exchange/db generate

ENV NODE_ENV=production

CMD ["pnpm", "--filter", "@forge-exchange/db", "migrate:prod"]
