APP_NAME="Forge Exchange"
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_HOST=localhost
PUBLIC_SITE_URL=http://localhost:3000

DATABASE_URL="postgresql://[USERNAME]:[YOUR-PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://[USERNAME]:[YOUR-PASSWORD]@[HOST]:5432/postgres"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="your-cloudinary-upload-preset"

REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

RESEND_API_KEY=""

NUXT_NODEMAILER_AUTH_USER="your-smtp-user@example.com"
NUXT_NODEMAILER_AUTH_PASS="your-smtp-password@example.com"
NUXT_NODEMAILER_FROM="Agc Forge <your-smtp-user@example.com>"

ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="your-admin-password"
ADMIN_NAME="your-admin-name"

NUXT_SESSION_PASSWORD=your-nuxt-session-password
APP_CLIENT_SECRET=your-app-client-secret

SANITY_PROJECT_ID="your-sanity-project-id"
SANITY_DATASET="your-sanity-dataset"
NUXT_SANITY_TOKEN=your-nuxt-sanity-token
